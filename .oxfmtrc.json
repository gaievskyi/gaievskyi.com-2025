{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": false,
  "trailingComma": "all",
  "semi": false,
  "endOfLine": "lf",
  "arrowParens": "always",
  "sortPackageJson": true,
  "ignorePatterns": [
    "*.gen.ts",
    "node_modules/**",
    ".next/**",
    "src/app/(payload)/**",
    ".agents/**",
    ".cursor/**",
    "payload-types.ts"
  ]
}
